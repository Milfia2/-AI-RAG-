# =============================================
# LiteLLM 設定（助教提供，用於 Chat Completion）
# =============================================
LITELLM_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LITELLM_BASE_URL=https://XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 預設 LLM 模型（可切換）
# gemini-2.5-flash：有每人 $3 美元額度上限
# gpt-oss-20b：無限制（本地端，速度可能較慢）
DEFAULT_LLM_MODEL=gpt-oss:20b

# =============================================
# Embedding Model 設定
# 選項 A（推薦）：sentence-transformers 本地模型，完全免費
# =============================================
# EMBEDDING_PROVIDER=sentence-transformers
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 選項 B：HuggingFace Inference API（免費額度）
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# =============================================
# Vector DB 設定
# =============================================
# ChromaDB（本作業選用，無需 Docker）
CHROMA_PERSIST_DIR=./chroma_db

# pgvector（若改用，需搭配 docker-compose.yml）
# PGVECTOR_CONNECTION_STRING=postgresql://raguser:ragpassword@localhost:5432/ragdb

# =============================================
# Chunking 設定（可選，有預設值）
# =============================================
CHUNK_SIZE=800
CHUNK_OVERLAP=150
DEFAULT_TOP_K=6
